   9739  4fd4							; every bank has this stuff at the same place
   9740  4fd4							; this code can switch to/from any bank at any entry point
   9741  4fd4							; and can preserve register values
   9742  4fd4							; note: lines not starting with a space are not placed in all banks
   9743  4fd4							;
   9744  4fd4							; line below tells the compiler how long this is - do not remove
   9745  4fd4							;size=32
