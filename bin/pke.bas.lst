   9456  4fd4							; every bank has this stuff at the same place
   9457  4fd4							; this code can switch to/from any bank at any entry point
   9458  4fd4							; and can preserve register values
   9459  4fd4							; note: lines not starting with a space are not placed in all banks
   9460  4fd4							;
   9461  4fd4							; line below tells the compiler how long this is - do not remove
   9462  4fd4							;size=32
   9463  4fd4
   9464  4fd4				   begin_bscode
   9465  4fd4		       a2 ff		      ldx	#$ff
   9466  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   9467  4fd6				  -	      stx	FASTFETCH
   9468  4fd6					      endif
   9469  4fd6		       9a		      txs
   9470  4fd7				  -	      if	bankswitch == 64
   9471  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   9472  4fd7					      else
   9473  4fd7		       a9 f3		      lda	#>(start-1)
   9474  4fd9					      endif
   9475  4fd9		       48		      pha
   9476  4fda		       a9 51		      lda	#<(start-1)
   9477  4fdc		       48		      pha
   9478  4fdd
   9479  4fdd				   BS_return
   9480  4fdd		       48		      pha
   9481  4fde		       8a		      txa
   9482  4fdf		       48		      pha
   9483  4fe0		       ba		      tsx
   9484  4fe1
   9485  4fe1					      if	bankswitch != 64
   9486  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   9487  4fe3
   9488  4fe3		       2a		      rol
   9489  4fe4		       2a		      rol
   9490  4fe5		       2a		      rol
   9491  4fe6		       2a		      rol
   9492  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   9493  4fe9		       aa		      tax
   9494  4fea		       e8		      inx
   9495  4feb				  -	      else
   9496  4feb				  -	      lda	4,x	; get high byte of return address
   9497  4feb				  -	      tay
   9498  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   9499  4feb				  -	      sta	4,x
   9500  4feb				  -	      tya
   9501  4feb				  -	      lsr
   9502  4feb				  -	      lsr
   9503  4feb				  -	      lsr
