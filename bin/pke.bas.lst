   9801  4ff2
   9802  4ff2					      ifconst	bankswitch
   9803  4ff2				  -	      if	bankswitch == 8
   9804  4ff2				  -	      ORG	$2FFC
   9805  4ff2				  -	      RORG	$FFFC
   9806  4ff2					      endif
   9807  4ff2					      if	bankswitch == 16
   9808  4ffc					      ORG	$4FFC
   9809  4ffc					      RORG	$FFFC
   9810  4ffc					      endif
   9811  4ffc				  -	      if	bankswitch == 32
   9812  4ffc				  -	      ORG	$8FFC
   9813  4ffc				  -	      RORG	$FFFC
   9814  4ffc					      endif
   9815  4ffc				  -	      if	bankswitch == 64
   9816  4ffc				  -	      ORG	$10FF0
   9817  4ffc				  -	      RORG	$1FFF0
   9818  4ffc				  -	      lda	$ffe0	; we use wasted space to assist stella with EF format auto-detection
   9819  4ffc				  -	      ORG	$10FF8
   9820  4ffc				  -	      RORG	$1FFF8
