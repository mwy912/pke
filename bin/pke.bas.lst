   7693  4fd4					      endif
   7694  4fd4							; Provided under the CC0 license. See the included LICENSE.txt for details.
   7695  4fd4
   7696  4fd4							; every bank has this stuff at the same place
   7697  4fd4							; this code can switch to/from any bank at any entry point
   7698  4fd4							; and can preserve register values
   7699  4fd4							; note: lines not starting with a space are not placed in all banks
   7700  4fd4							;
   7701  4fd4							; line below tells the compiler how long this is - do not remove
   7702  4fd4							;size=32
   7703  4fd4
   7704  4fd4				   begin_bscode
   7705  4fd4		       a2 ff		      ldx	#$ff
   7706  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   7707  4fd6				  -	      stx	FASTFETCH
   7708  4fd6					      endif
   7709  4fd6		       9a		      txs
   7710  4fd7				  -	      if	bankswitch == 64
   7711  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   7712  4fd7					      else
   7713  4fd7		       a9 f3		      lda	#>(start-1)
   7714  4fd9					      endif
   7715  4fd9		       48		      pha
   7716  4fda		       a9 51		      lda	#<(start-1)
   7717  4fdc		       48		      pha
   7718  4fdd
   7719  4fdd				   BS_return
   7720  4fdd		       48		      pha
   7721  4fde		       8a		      txa
   7722  4fdf		       48		      pha
   7723  4fe0		       ba		      tsx
   7724  4fe1
   7725  4fe1					      if	bankswitch != 64
   7726  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   7727  4fe3
   7728  4fe3		       2a		      rol
   7729  4fe4		       2a		      rol
   7730  4fe5		       2a		      rol
   7731  4fe6		       2a		      rol
   7732  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   7733  4fe9		       aa		      tax
   7734  4fea		       e8		      inx
   7735  4feb				  -	      else
   7736  4feb				  -	      lda	4,x	; get high byte of return address
   7737  4feb				  -	      tay
   7738  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   7739  4feb				  -	      sta	4,x
   7740  4feb				  -	      tya
   7741  4feb				  -	      lsr
   7742  4feb				  -	      lsr
   7743  4feb				  -	      lsr
   7744  4feb				  -	      lsr
   7745  4feb				  -	      tax
   7746  4feb				  -	      inx
   7747  4feb					      endif
   7748  4feb
   7749  4feb				   BS_jsr
   7750  4feb		       bd f5 1f 	      lda	bankswitch_hotspot-1,x
   7751  4fee		       68		      pla
   7752  4fef		       aa		      tax
   7753  4ff0		       68		      pla
   7754  4ff1		       60		      rts
   7755  4ff2				  -	      if	((* & $1FFF) > ((bankswitch_hotspot & $1FFF) - 1))
   7756  4ff2				  -	      echo	"WARNING: size parameter in banksw.asm too small - the program probably will not work."
   7757  4ff2				  -	      echo	"Change to",[(*-begin_bscode+1)&$FF]d,"and try again."
   7758  4ff2					      endif
   7759  4ff2							; Provided under the CC0 license. See the included LICENSE.txt for details.
   7760  4ff2
   7761  4ff2					      ifconst	bankswitch
   7762  4ff2				  -	      if	bankswitch == 8
   7763  4ff2				  -	      ORG	$2FFC
   7764  4ff2				  -	      RORG	$FFFC
   7765  4ff2					      endif
   7766  4ff2					      if	bankswitch == 16
   7767  4ffc					      ORG	$4FFC
   7768  4ffc					      RORG	$FFFC
   7769  4ffc					      endif
   7770  4ffc				  -	      if	bankswitch == 32
   7771  4ffc				  -	      ORG	$8FFC
   7772  4ffc				  -	      RORG	$FFFC
   7773  4ffc					      endif
   7774  4ffc				  -	      if	bankswitch == 64
   7775  4ffc				  -	      ORG	$10FF0
   7776  4ffc				  -	      RORG	$1FFF0
   7777  4ffc				  -	      lda	$ffe0	; we use wasted space to assist stella with EF format auto-detection
   7778  4ffc				  -	      ORG	$10FF8
   7779  4ffc				  -	      RORG	$1FFF8
   7780  4ffc				  -	      ifconst	superchip
   7781  4ffc				  -	      .byte	"E","F","S","C"
   7782  4ffc				  -	      else
   7783  4ffc				  -	      .byte	"E","F","E","F"
   7784  4ffc				  -	      endif
   7785  4ffc				  -	      ORG	$10FFC
   7786  4ffc				  -	      RORG	$1FFFC
   7787  4ffc					      endif
   7788  4ffc				  -	      else
   7789  4ffc				  -	      ifconst	ROM2k
   7790  4ffc				  -	      ORG	$F7FC
   7791  4ffc				  -	      else
   7792  4ffc				  -	      ORG	$FFFC
   7793  4ffc				  -	      endif
   7794  4ffc					      endif
   7795  4ffc		       52 f3		      .word.w	(start & $ffff)
   7796  4ffe		       52 f3		      .word.w	(start & $ffff)
