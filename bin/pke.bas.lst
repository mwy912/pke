   8126  4fd4					      endif
   8127  4fd4					      endif
   8128  4fd4					      endif
   8129  4fd4							; Provided under the CC0 license. See the included LICENSE.txt for details.
   8130  4fd4
   8131  4fd4							; every bank has this stuff at the same place
   8132  4fd4							; this code can switch to/from any bank at any entry point
   8133  4fd4							; and can preserve register values
   8134  4fd4							; note: lines not starting with a space are not placed in all banks
   8135  4fd4							;
   8136  4fd4							; line below tells the compiler how long this is - do not remove
   8137  4fd4							;size=32
   8138  4fd4
   8139  4fd4				   begin_bscode
   8140  4fd4		       a2 ff		      ldx	#$ff
   8141  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   8142  4fd6				  -	      stx	FASTFETCH
   8143  4fd6					      endif
   8144  4fd6		       9a		      txs
   8145  4fd7				  -	      if	bankswitch == 64
   8146  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   8147  4fd7					      else
   8148  4fd7		       a9 f3		      lda	#>(start-1)
   8149  4fd9					      endif
   8150  4fd9		       48		      pha
   8151  4fda		       a9 51		      lda	#<(start-1)
   8152  4fdc		       48		      pha
   8153  4fdd
   8154  4fdd				   BS_return
   8155  4fdd		       48		      pha
   8156  4fde		       8a		      txa
   8157  4fdf		       48		      pha
   8158  4fe0		       ba		      tsx
   8159  4fe1
   8160  4fe1					      if	bankswitch != 64
   8161  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   8162  4fe3
   8163  4fe3		       2a		      rol
   8164  4fe4		       2a		      rol
   8165  4fe5		       2a		      rol
   8166  4fe6		       2a		      rol
   8167  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   8168  4fe9		       aa		      tax
   8169  4fea		       e8		      inx
   8170  4feb				  -	      else
   8171  4feb				  -	      lda	4,x	; get high byte of return address
   8172  4feb				  -	      tay
   8173  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   8174  4feb				  -	      sta	4,x
   8175  4feb				  -	      tya
   8176  4feb				  -	      lsr
   8177  4feb				  -	      lsr
   8178  4feb				  -	      lsr
   8179  4feb				  -	      lsr
   8180  4feb				  -	      tax
   8181  4feb				  -	      inx
   8182  4feb					      endif
   8183  4feb
   8184  4feb				   BS_jsr
   8185  4feb		       bd f5 1f 	      lda	bankswitch_hotspot-1,x
   8186  4fee		       68		      pla
   8187  4fef		       aa		      tax
   8188  4ff0		       68		      pla
   8189  4ff1		       60		      rts
   8190  4ff2				  -	      if	((* & $1FFF) > ((bankswitch_hotspot & $1FFF) - 1))
   8191  4ff2				  -	      echo	"WARNING: size parameter in banksw.asm too small - the program probably will not work."
   8192  4ff2				  -	      echo	"Change to",[(*-begin_bscode+1)&$FF]d,"and try again."
   8193  4ff2					      endif
   8194  4ff2							; Provided under the CC0 license. See the included LICENSE.txt for details.
   8195  4ff2
   8196  4ff2					      ifconst	bankswitch
   8197  4ff2				  -	      if	bankswitch == 8
   8198  4ff2				  -	      ORG	$2FFC
   8199  4ff2				  -	      RORG	$FFFC
   8200  4ff2					      endif
   8201  4ff2					      if	bankswitch == 16
   8202  4ffc					      ORG	$4FFC
   8203  4ffc					      RORG	$FFFC
   8204  4ffc					      endif
   8205  4ffc				  -	      if	bankswitch == 32
   8206  4ffc				  -	      ORG	$8FFC
   8207  4ffc				  -	      RORG	$FFFC
   8208  4ffc					      endif
   8209  4ffc				  -	      if	bankswitch == 64
   8210  4ffc				  -	      ORG	$10FF0
   8211  4ffc				  -	      RORG	$1FFF0
   8212  4ffc				  -	      lda	$ffe0	; we use wasted space to assist stella with EF format auto-detection
   8213  4ffc				  -	      ORG	$10FF8
   8214  4ffc				  -	      RORG	$1FFF8
   8215  4ffc				  -	      ifconst	superchip
   8216  4ffc				  -	      .byte	"E","F","S","C"
   8217  4ffc				  -	      else
   8218  4ffc				  -	      .byte	"E","F","E","F"
   8219  4ffc				  -	      endif
   8220  4ffc				  -	      ORG	$10FFC
   8221  4ffc				  -	      RORG	$1FFFC
   8222  4ffc					      endif
   8223  4ffc				  -	      else
   8224  4ffc				  -	      ifconst	ROM2k
   8225  4ffc				  -	      ORG	$F7FC
   8226  4ffc				  -	      else
   8227  4ffc				  -	      ORG	$FFFC
   8228  4ffc				  -	      endif
   8229  4ffc					      endif
   8230  4ffc		       52 f3		      .word.w	(start & $ffff)
   8231  4ffe		       52 f3		      .word.w	(start & $ffff)
