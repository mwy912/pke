   9736  4fd4
   9737  4fd4							; every bank has this stuff at the same place
   9738  4fd4							; this code can switch to/from any bank at any entry point
   9739  4fd4							; and can preserve register values
   9740  4fd4							; note: lines not starting with a space are not placed in all banks
   9741  4fd4							;
   9742  4fd4							; line below tells the compiler how long this is - do not remove
   9743  4fd4							;size=32
   9744  4fd4
   9745  4fd4				   begin_bscode
   9746  4fd4		       a2 ff		      ldx	#$ff
   9747  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   9748  4fd6				  -	      stx	FASTFETCH
   9749  4fd6					      endif
   9750  4fd6		       9a		      txs
   9751  4fd7				  -	      if	bankswitch == 64
   9752  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   9753  4fd7					      else
   9754  4fd7		       a9 f3		      lda	#>(start-1)
   9755  4fd9					      endif
   9756  4fd9		       48		      pha
   9757  4fda		       a9 51		      lda	#<(start-1)
   9758  4fdc		       48		      pha
   9759  4fdd
   9760  4fdd				   BS_return
   9761  4fdd		       48		      pha
   9762  4fde		       8a		      txa
   9763  4fdf		       48		      pha
   9764  4fe0		       ba		      tsx
   9765  4fe1
   9766  4fe1					      if	bankswitch != 64
   9767  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   9768  4fe3
   9769  4fe3		       2a		      rol
   9770  4fe4		       2a		      rol
   9771  4fe5		       2a		      rol
   9772  4fe6		       2a		      rol
   9773  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   9774  4fe9		       aa		      tax
   9775  4fea		       e8		      inx
   9776  4feb				  -	      else
   9777  4feb				  -	      lda	4,x	; get high byte of return address
   9778  4feb				  -	      tay
   9779  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   9780  4feb				  -	      sta	4,x
   9781  4feb				  -	      tya
   9782  4feb				  -	      lsr
   9783  4feb				  -	      lsr
   9784  4feb				  -	      lsr
   9785  4feb				  -	      lsr
   9786  4feb				  -	      tax
   9787  4feb				  -	      inx
   9788  4feb					      endif
   9789  4feb
   9790  4feb				   BS_jsr
   9791  4feb		       bd f5 1f 	      lda	bankswitch_hotspot-1,x
   9792  4fee		       68		      pla
   9793  4fef		       aa		      tax
   9794  4ff0		       68		      pla
   9795  4ff1		       60		      rts
   9796  4ff2				  -	      if	((* & $1FFF) > ((bankswitch_hotspot & $1FFF) - 1))
   9797  4ff2				  -	      echo	"WARNING: size parameter in banksw.asm too small - the program probably will not work."
   9798  4ff2				  -	      echo	"Change to",[(*-begin_bscode+1)&$FF]d,"and try again."
   9799  4ff2					      endif
