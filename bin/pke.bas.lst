   9826  4fd4							; every bank has this stuff at the same place
   9827  4fd4							; this code can switch to/from any bank at any entry point
   9828  4fd4							; and can preserve register values
   9829  4fd4							; note: lines not starting with a space are not placed in all banks
   9830  4fd4							;
   9831  4fd4							; line below tells the compiler how long this is - do not remove
   9832  4fd4							;size=32
   9833  4fd4
   9834  4fd4				   begin_bscode
   9835  4fd4		       a2 ff		      ldx	#$ff
   9836  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   9837  4fd6				  -	      stx	FASTFETCH
   9838  4fd6					      endif
   9839  4fd6		       9a		      txs
   9840  4fd7				  -	      if	bankswitch == 64
   9841  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   9842  4fd7					      else
   9843  4fd7		       a9 f3		      lda	#>(start-1)
   9844  4fd9					      endif
   9845  4fd9		       48		      pha
   9846  4fda		       a9 51		      lda	#<(start-1)
   9847  4fdc		       48		      pha
   9848  4fdd
   9849  4fdd				   BS_return
   9850  4fdd		       48		      pha
   9851  4fde		       8a		      txa
   9852  4fdf		       48		      pha
   9853  4fe0		       ba		      tsx
   9854  4fe1
   9855  4fe1					      if	bankswitch != 64
   9856  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   9857  4fe3
   9858  4fe3		       2a		      rol
   9859  4fe4		       2a		      rol
   9860  4fe5		       2a		      rol
   9861  4fe6		       2a		      rol
   9862  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   9863  4fe9		       aa		      tax
   9864  4fea		       e8		      inx
   9865  4feb				  -	      else
   9866  4feb				  -	      lda	4,x	; get high byte of return address
   9867  4feb				  -	      tay
   9868  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   9869  4feb				  -	      sta	4,x
   9870  4feb				  -	      tya
   9871  4feb				  -	      lsr
   9872  4feb				  -	      lsr
   9873  4feb				  -	      lsr
