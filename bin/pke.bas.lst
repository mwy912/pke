   9822  4ffc				  -	      .byte	"E","F","S","C"
   9823  4ffc				  -	      else
   9824  4ffc				  -	      .byte	"E","F","E","F"
   9825  4ffc				  -	      endif
   9826  4ffc				  -	      ORG	$10FFC
   9827  4ffc				  -	      RORG	$1FFFC
   9828  4ffc					      endif
   9829  4ffc				  -	      else
   9830  4ffc				  -	      ifconst	ROM2k
   9831  4ffc				  -	      ORG	$F7FC
   9832  4ffc				  -	      else
   9833  4ffc				  -	      ORG	$FFFC
   9834  4ffc				  -	      endif
