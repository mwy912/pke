   8987  4fd4							; every bank has this stuff at the same place
   8988  4fd4							; this code can switch to/from any bank at any entry point
   8989  4fd4							; and can preserve register values
   8990  4fd4							; note: lines not starting with a space are not placed in all banks
   8991  4fd4							;
   8992  4fd4							; line below tells the compiler how long this is - do not remove
   8993  4fd4							;size=32
   8994  4fd4
   8995  4fd4				   begin_bscode
   8996  4fd4		       a2 ff		      ldx	#$ff
   8997  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   8998  4fd6				  -	      stx	FASTFETCH
   8999  4fd6					      endif
   9000  4fd6		       9a		      txs
   9001  4fd7				  -	      if	bankswitch == 64
   9002  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   9003  4fd7					      else
   9004  4fd7		       a9 f3		      lda	#>(start-1)
   9005  4fd9					      endif
   9006  4fd9		       48		      pha
   9007  4fda		       a9 51		      lda	#<(start-1)
   9008  4fdc		       48		      pha
   9009  4fdd
   9010  4fdd				   BS_return
   9011  4fdd		       48		      pha
   9012  4fde		       8a		      txa
   9013  4fdf		       48		      pha
   9014  4fe0		       ba		      tsx
   9015  4fe1
   9016  4fe1					      if	bankswitch != 64
   9017  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   9018  4fe3
   9019  4fe3		       2a		      rol
   9020  4fe4		       2a		      rol
   9021  4fe5		       2a		      rol
   9022  4fe6		       2a		      rol
   9023  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   9024  4fe9		       aa		      tax
   9025  4fea		       e8		      inx
   9026  4feb				  -	      else
   9027  4feb				  -	      lda	4,x	; get high byte of return address
   9028  4feb				  -	      tay
   9029  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   9030  4feb				  -	      sta	4,x
   9031  4feb				  -	      tya
   9032  4feb				  -	      lsr
   9033  4feb				  -	      lsr
   9034  4feb				  -	      lsr
   9035  4feb				  -	      lsr
   9036  4feb				  -	      tax
   9037  4feb				  -	      inx
   9038  4feb					      endif
   9039  4feb
   9040  4feb				   BS_jsr
   9041  4feb		       bd f5 1f 	      lda	bankswitch_hotspot-1,x
   9042  4fee		       68		      pla
   9043  4fef		       aa		      tax
   9044  4ff0		       68		      pla
   9045  4ff1		       60		      rts
   9046  4ff2				  -	      if	((* & $1FFF) > ((bankswitch_hotspot & $1FFF) - 1))
   9047  4ff2				  -	      echo	"WARNING: size parameter in banksw.asm too small - the program probably will not work."
   9048  4ff2				  -	      echo	"Change to",[(*-begin_bscode+1)&$FF]d,"and try again."
   9049  4ff2					      endif
