   9748  4fd4		       a2 ff		      ldx	#$ff
   9749  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   9750  4fd6				  -	      stx	FASTFETCH
   9751  4fd6					      endif
   9752  4fd6		       9a		      txs
   9753  4fd7				  -	      if	bankswitch == 64
   9754  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   9755  4fd7					      else
   9756  4fd7		       a9 f3		      lda	#>(start-1)
   9757  4fd9					      endif
   9758  4fd9		       48		      pha
   9759  4fda		       a9 51		      lda	#<(start-1)
   9760  4fdc		       48		      pha
   9761  4fdd
   9762  4fdd				   BS_return
   9763  4fdd		       48		      pha
   9764  4fde		       8a		      txa
   9765  4fdf		       48		      pha
   9766  4fe0		       ba		      tsx
   9767  4fe1
   9768  4fe1					      if	bankswitch != 64
   9769  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   9770  4fe3
   9771  4fe3		       2a		      rol
   9772  4fe4		       2a		      rol
   9773  4fe5		       2a		      rol
   9774  4fe6		       2a		      rol
   9775  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   9776  4fe9		       aa		      tax
   9777  4fea		       e8		      inx
   9778  4feb				  -	      else
   9779  4feb				  -	      lda	4,x	; get high byte of return address
   9780  4feb				  -	      tay
   9781  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   9782  4feb				  -	      sta	4,x
   9783  4feb				  -	      tya
   9784  4feb				  -	      lsr
   9785  4feb				  -	      lsr
   9786  4feb				  -	      lsr
   9787  4feb				  -	      lsr
   9788  4feb				  -	      tax
   9789  4feb				  -	      inx
   9790  4feb					      endif
   9791  4feb
   9792  4feb				   BS_jsr
   9793  4feb		       bd f5 1f 	      lda	bankswitch_hotspot-1,x
   9794  4fee		       68		      pla
   9795  4fef		       aa		      tax
   9796  4ff0		       68		      pla
   9797  4ff1		       60		      rts
   9798  4ff2				  -	      if	((* & $1FFF) > ((bankswitch_hotspot & $1FFF) - 1))
   9799  4ff2				  -	      echo	"WARNING: size parameter in banksw.asm too small - the program probably will not work."
   9800  4ff2				  -	      echo	"Change to",[(*-begin_bscode+1)&$FF]d,"and try again."
   9801  4ff2					      endif
