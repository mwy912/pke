   9804  4ff2					      ifconst	bankswitch
   9805  4ff2				  -	      if	bankswitch == 8
   9806  4ff2				  -	      ORG	$2FFC
   9807  4ff2				  -	      RORG	$FFFC
   9808  4ff2					      endif
   9809  4ff2					      if	bankswitch == 16
