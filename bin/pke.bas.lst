   8649  4ff2					      ifconst	bankswitch
   8650  4ff2				  -	      if	bankswitch == 8
   8651  4ff2				  -	      ORG	$2FFC
   8652  4ff2				  -	      RORG	$FFFC
   8653  4ff2					      endif
   8654  4ff2					      if	bankswitch == 16
