   9716  4fcc				  -	      RORG	$FFF4-bscode_length
   9717  4fcc					      endif
   9718  4fcc					      if	bankswitch == 16
   9719  4fd4					      ORG	$4FF4-bscode_length
   9720  4fd4					      RORG	$FFF4-bscode_length
   9721  4fd4					      endif
   9722  4fd4				  -	      if	bankswitch == 32
   9723  4fd4				  -	      ORG	$8FF4-bscode_length
   9724  4fd4				  -	      RORG	$FFF4-bscode_length
   9725  4fd4					      endif
   9726  4fd4				  -	      if	bankswitch == 64
   9727  4fd4				  -	      ORG	$10FE0-bscode_length
   9728  4fd4				  -	      RORG	$1FFE0-bscode_length
   9729  4fd4					      endif
   9730  4fd4				  -	      else
   9731  4fd4				  -	      ORG	$FFFC
   9732  4fd4					      endif
   9733  4fd4					      endif
   9734  4fd4					      endif
