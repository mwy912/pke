   7482  4fd4							; every bank has this stuff at the same place
   7483  4fd4							; this code can switch to/from any bank at any entry point
   7484  4fd4							; and can preserve register values
   7485  4fd4							; note: lines not starting with a space are not placed in all banks
   7486  4fd4							;
   7487  4fd4							; line below tells the compiler how long this is - do not remove
   7488  4fd4							;size=32
