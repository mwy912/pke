   5352  3100					      if	ECHO3
      3796 bytes of ROM space left in bank 3
   5353  3100					      echo	"    ",[(start_bank3 - *)]d , "bytes of ROM space left in bank 3")
   5354  3100					      endif
   5355  3100		       00 01	   ECHO3      =	1
   5356  3fd4					      ORG	$3FF4-bscode_length
   5357  3fd4					      RORG	$DFF4-bscode_length
