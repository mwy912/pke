   8613  4fd4							; every bank has this stuff at the same place
   8614  4fd4							; this code can switch to/from any bank at any entry point
   8615  4fd4							; and can preserve register values
   8616  4fd4							; note: lines not starting with a space are not placed in all banks
   8617  4fd4							;
   8618  4fd4							; line below tells the compiler how long this is - do not remove
   8619  4fd4							;size=32
   8620  4fd4
   8621  4fd4				   begin_bscode
   8622  4fd4		       a2 ff		      ldx	#$ff
   8623  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   8624  4fd6				  -	      stx	FASTFETCH
   8625  4fd6					      endif
   8626  4fd6		       9a		      txs
   8627  4fd7				  -	      if	bankswitch == 64
   8628  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   8629  4fd7					      else
   8630  4fd7		       a9 f3		      lda	#>(start-1)
   8631  4fd9					      endif
   8632  4fd9		       48		      pha
   8633  4fda		       a9 51		      lda	#<(start-1)
   8634  4fdc		       48		      pha
   8635  4fdd
   8636  4fdd				   BS_return
   8637  4fdd		       48		      pha
   8638  4fde		       8a		      txa
   8639  4fdf		       48		      pha
   8640  4fe0		       ba		      tsx
   8641  4fe1
   8642  4fe1					      if	bankswitch != 64
   8643  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   8644  4fe3
   8645  4fe3		       2a		      rol
   8646  4fe4		       2a		      rol
   8647  4fe5		       2a		      rol
   8648  4fe6		       2a		      rol
   8649  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   8650  4fe9		       aa		      tax
   8651  4fea		       e8		      inx
   8652  4feb				  -	      else
   8653  4feb				  -	      lda	4,x	; get high byte of return address
   8654  4feb				  -	      tay
   8655  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   8656  4feb				  -	      sta	4,x
   8657  4feb				  -	      tya
   8658  4feb				  -	      lsr
   8659  4feb				  -	      lsr
   8660  4feb				  -	      lsr
   8661  4feb				  -	      lsr
   8662  4feb				  -	      tax
   8663  4feb				  -	      inx
   8664  4feb					      endif
   8665  4feb
   8666  4feb				   BS_jsr
   8667  4feb		       bd f5 1f 	      lda	bankswitch_hotspot-1,x
   8668  4fee		       68		      pla
   8669  4fef		       aa		      tax
   8670  4ff0		       68		      pla
   8671  4ff1		       60		      rts
   8672  4ff2				  -	      if	((* & $1FFF) > ((bankswitch_hotspot & $1FFF) - 1))
   8673  4ff2				  -	      echo	"WARNING: size parameter in banksw.asm too small - the program probably will not work."
   8674  4ff2				  -	      echo	"Change to",[(*-begin_bscode+1)&$FF]d,"and try again."
   8675  4ff2					      endif
