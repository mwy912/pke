   7490  4fd4				   begin_bscode
   7491  4fd4		       a2 ff		      ldx	#$ff
   7492  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   7493  4fd6				  -	      stx	FASTFETCH
   7494  4fd6					      endif
   7495  4fd6		       9a		      txs
   7496  4fd7				  -	      if	bankswitch == 64
   7497  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   7498  4fd7					      else
   7499  4fd7		       a9 f3		      lda	#>(start-1)
   7500  4fd9					      endif
   7501  4fd9		       48		      pha
