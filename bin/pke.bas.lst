   7706  4fd4				  -	      ORG	$FFFC
   7707  4fd4					      endif
   7708  4fd4					      endif
   7709  4fd4					      endif
   7710  4fd4							; Provided under the CC0 license. See the included LICENSE.txt for details.
   7711  4fd4
   7712  4fd4							; every bank has this stuff at the same place
   7713  4fd4							; this code can switch to/from any bank at any entry point
   7714  4fd4							; and can preserve register values
   7715  4fd4							; note: lines not starting with a space are not placed in all banks
   7716  4fd4							;
   7717  4fd4							; line below tells the compiler how long this is - do not remove
   7718  4fd4							;size=32
   7719  4fd4
   7720  4fd4				   begin_bscode
   7721  4fd4		       a2 ff		      ldx	#$ff
   7722  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   7723  4fd6				  -	      stx	FASTFETCH
   7724  4fd6					      endif
   7725  4fd6		       9a		      txs
   7726  4fd7				  -	      if	bankswitch == 64
   7727  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   7728  4fd7					      else
   7729  4fd7		       a9 f3		      lda	#>(start-1)
   7730  4fd9					      endif
   7731  4fd9		       48		      pha
   7732  4fda		       a9 51		      lda	#<(start-1)
   7733  4fdc		       48		      pha
   7734  4fdd
   7735  4fdd				   BS_return
   7736  4fdd		       48		      pha
   7737  4fde		       8a		      txa
   7738  4fdf		       48		      pha
   7739  4fe0		       ba		      tsx
   7740  4fe1
   7741  4fe1					      if	bankswitch != 64
   7742  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   7743  4fe3
   7744  4fe3		       2a		      rol
   7745  4fe4		       2a		      rol
   7746  4fe5		       2a		      rol
   7747  4fe6		       2a		      rol
   7748  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   7749  4fe9		       aa		      tax
   7750  4fea		       e8		      inx
   7751  4feb				  -	      else
   7752  4feb				  -	      lda	4,x	; get high byte of return address
   7753  4feb				  -	      tay
   7754  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   7755  4feb				  -	      sta	4,x
   7756  4feb				  -	      tya
   7757  4feb				  -	      lsr
   7758  4feb				  -	      lsr
   7759  4feb				  -	      lsr
   7760  4feb				  -	      lsr
   7761  4feb				  -	      tax
   7762  4feb				  -	      inx
   7763  4feb					      endif
   7764  4feb
   7765  4feb				   BS_jsr
   7766  4feb		       bd f5 1f 	      lda	bankswitch_hotspot-1,x
   7767  4fee		       68		      pla
   7768  4fef		       aa		      tax
   7769  4ff0		       68		      pla
   7770  4ff1		       60		      rts
   7771  4ff2				  -	      if	((* & $1FFF) > ((bankswitch_hotspot & $1FFF) - 1))
   7772  4ff2				  -	      echo	"WARNING: size parameter in banksw.asm too small - the program probably will not work."
   7773  4ff2				  -	      echo	"Change to",[(*-begin_bscode+1)&$FF]d,"and try again."
   7774  4ff2					      endif
   7775  4ff2							; Provided under the CC0 license. See the included LICENSE.txt for details.
   7776  4ff2
   7777  4ff2					      ifconst	bankswitch
   7778  4ff2				  -	      if	bankswitch == 8
   7779  4ff2				  -	      ORG	$2FFC
   7780  4ff2				  -	      RORG	$FFFC
   7781  4ff2					      endif
   7782  4ff2					      if	bankswitch == 16
   7783  4ffc					      ORG	$4FFC
   7784  4ffc					      RORG	$FFFC
   7785  4ffc					      endif
   7786  4ffc				  -	      if	bankswitch == 32
   7787  4ffc				  -	      ORG	$8FFC
   7788  4ffc				  -	      RORG	$FFFC
   7789  4ffc					      endif
   7790  4ffc				  -	      if	bankswitch == 64
   7791  4ffc				  -	      ORG	$10FF0
   7792  4ffc				  -	      RORG	$1FFF0
   7793  4ffc				  -	      lda	$ffe0	; we use wasted space to assist stella with EF format auto-detection
   7794  4ffc				  -	      ORG	$10FF8
   7795  4ffc				  -	      RORG	$1FFF8
   7796  4ffc				  -	      ifconst	superchip
   7797  4ffc				  -	      .byte	"E","F","S","C"
   7798  4ffc				  -	      else
   7799  4ffc				  -	      .byte	"E","F","E","F"
   7800  4ffc				  -	      endif
   7801  4ffc				  -	      ORG	$10FFC
   7802  4ffc				  -	      RORG	$1FFFC
   7803  4ffc					      endif
   7804  4ffc				  -	      else
   7805  4ffc				  -	      ifconst	ROM2k
   7806  4ffc				  -	      ORG	$F7FC
   7807  4ffc				  -	      else
   7808  4ffc				  -	      ORG	$FFFC
   7809  4ffc				  -	      endif
   7810  4ffc					      endif
   7811  4ffc		       52 f3		      .word.w	(start & $ffff)
   7812  4ffe		       52 f3		      .word.w	(start & $ffff)
