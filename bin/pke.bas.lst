   8584  4fd4							; every bank has this stuff at the same place
   8585  4fd4							; this code can switch to/from any bank at any entry point
   8586  4fd4							; and can preserve register values
   8587  4fd4							; note: lines not starting with a space are not placed in all banks
   8588  4fd4							;
   8589  4fd4							; line below tells the compiler how long this is - do not remove
   8590  4fd4							;size=32
   8591  4fd4
   8592  4fd4				   begin_bscode
   8593  4fd4		       a2 ff		      ldx	#$ff
   8594  4fd6				  -	      ifconst	FASTFETCH	; using DPC+
   8595  4fd6				  -	      stx	FASTFETCH
   8596  4fd6					      endif
   8597  4fd6		       9a		      txs
   8598  4fd7				  -	      if	bankswitch == 64
   8599  4fd7				  -	      lda	#(((>(start-1)) & $0F) | $F0)
   8600  4fd7					      else
   8601  4fd7		       a9 f3		      lda	#>(start-1)
   8602  4fd9					      endif
   8603  4fd9		       48		      pha
   8604  4fda		       a9 51		      lda	#<(start-1)
   8605  4fdc		       48		      pha
   8606  4fdd
   8607  4fdd				   BS_return
   8608  4fdd		       48		      pha
   8609  4fde		       8a		      txa
   8610  4fdf		       48		      pha
   8611  4fe0		       ba		      tsx
   8612  4fe1
   8613  4fe1					      if	bankswitch != 64
   8614  4fe1		       b5 04		      lda	4,x	; get high byte of return address
   8615  4fe3
   8616  4fe3		       2a		      rol
   8617  4fe4		       2a		      rol
   8618  4fe5		       2a		      rol
   8619  4fe6		       2a		      rol
   8620  4fe7		       29 03		      and	#bs_mask	;1 3 or 7 for F8/F6/F4
   8621  4fe9		       aa		      tax
   8622  4fea		       e8		      inx
   8623  4feb				  -	      else
   8624  4feb				  -	      lda	4,x	; get high byte of return address
   8625  4feb				  -	      tay
   8626  4feb				  -	      ora	#$10	; change our bank nibble into a valid rom mirror
   8627  4feb				  -	      sta	4,x
   8628  4feb				  -	      tya
   8629  4feb				  -	      lsr
   8630  4feb				  -	      lsr
   8631  4feb				  -	      lsr
   8632  4feb				  -	      lsr
   8633  4feb				  -	      tax
   8634  4feb				  -	      inx
   8635  4feb					      endif
   8636  4feb
   8637  4feb				   BS_jsr
   8638  4feb		       bd f5 1f 	      lda	bankswitch_hotspot-1,x
   8639  4fee		       68		      pla
   8640  4fef		       aa		      tax
   8641  4ff0		       68		      pla
   8642  4ff1		       60		      rts
   8643  4ff2				  -	      if	((* & $1FFF) > ((bankswitch_hotspot & $1FFF) - 1))
   8644  4ff2				  -	      echo	"WARNING: size parameter in banksw.asm too small - the program probably will not work."
   8645  4ff2				  -	      echo	"Change to",[(*-begin_bscode+1)&$FF]d,"and try again."
   8646  4ff2					      endif
